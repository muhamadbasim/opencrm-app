# ============================================================
# OpenCRM Production Environment
# ============================================================
# Copy this to .env.production and fill in real values.
# Used by: docker-compose (deploy/vps/docker-compose.yml)
# ============================================================

# --- Core URLs (replace with your actual domain) ---
FRONTEND_URL=https://crm.yourdomain.com
BACKEND_URL=https://api.yourdomain.com
API_PUBLIC_URL=https://api.yourdomain.com
PUBLIC_API_BASE_URL=https://api.yourdomain.com
BETTER_AUTH_URL=https://api.yourdomain.com
BETTER_AUTH_BASE_URL=https://api.yourdomain.com

# --- Infrastructure ---
DATABASE_URL=postgresql://postgres:CHANGE_THIS_PASSWORD@postgres:5432/opencrm_db
REDIS_URL=redis://redis:6379
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# --- Auth Secrets (generate with: openssl rand -base64 32) ---
BETTER_AUTH_SECRET=
SESSION_SECRET=
JWT_SECRET=
DEVELOPER_API_KEY_SECRET=
N8N_EMBED_AUTH_SECRET=

# --- App Config ---
NODE_ENV=production
APP_MODE=api
PORT=3010
SOCKET_PORT=3011
SOCKET_IO_PATH=/socket-io
SOCKET_IO_CORS_ORIGIN=https://crm.yourdomain.com
SOCKET_IO_TRANSPORTS=websocket,polling

# --- Frontend Build Args ---
VITE_API_URL=https://api.yourdomain.com
VITE_SOCKET_URL=https://api.yourdomain.com
VITE_SOCKET_PATH=/socket-io

# --- AI (optional) ---
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# --- WhatsApp / Meta (optional) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_CALLBACK_URL=https://api.yourdomain.com/api/v1/webhooks/whatsapp
WHATSAPP_REDIRECT_URI=https://api.yourdomain.com/api/v1/whatsapp-channels/callback
META_VERIFY_TOKEN=
FB_APP_ID=
FB_APP_SECRET=

# --- Baileys WhatsApp (optional) ---
BAILEYS_SERVICE_URL=
BAILEYS_SERVICE_INTERNAL_TOKEN=
BAILEYS_PROVIDER_WEBHOOK_URL=https://api.yourdomain.com/api/v1/webhooks/whatsapp/baileys
BAILEYS_PROVIDER_WEBHOOK_PATH=/api/v1/webhooks/whatsapp/baileys

# --- Storage R2/S3 (optional) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_REGION=auto

# --- Payment / Pakasir (optional) ---
PAKASIR_MODE=live
PAKASIR_BASE_URL=
PAKASIR_LIVE_BASE_URL=
PAKASIR_API_KEY=
PAKASIR_PROJECT=
PAKASIR_PROJECT_SLUG=
PAKASIR_REDIRECT_URL=https://crm.yourdomain.com/payment/success

# --- Tunnel (disabled in production) ---
ENABLE_TUNNEL=false
