# Root environment example for local development
# Copy to .env before running helper scripts.

# Local app URLs
FRONTEND_URL=http://localhost:3005
BACKEND_URL=http://localhost:3010
API_PUBLIC_URL=http://localhost:3010
PUBLIC_API_BASE_URL=http://localhost:3010

# Local infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opencrm_db
REDIS_URL=redis://localhost:6379

# Auth / app secrets
BETTER_AUTH_URL=http://localhost:3010
BETTER_AUTH_BASE_URL=http://localhost:3010
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-secret
DEVELOPER_API_KEY_SECRET=replace-with-a-long-random-secret
N8N_EMBED_AUTH_SECRET=replace-with-a-long-random-secret

# Optional local tunnel helpers used by run-*.sh
CLOUDFLARED_TUNNEL_TOKEN=
TUNNEL_FE_HOST=local-fe.scalebiz.chat
TUNNEL_API_HOST=local-api.scalebiz.chat
ENABLE_TUNNEL=false
ENABLE_TUNNEL_HMR=false

# Ports / mode
PORT=3010
SOCKET_PORT=3011
APP_MODE=api
SOCKET_IO_PATH=/socket-io
SOCKET_IO_CORS_ORIGIN=http://localhost:3005
SOCKET_IO_TRANSPORTS=websocket,polling
